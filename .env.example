# Notion integration token (https://www.notion.so/profile/integrations)
NOTION_API_KEY=secret_xxx

# Notion database IDs — find in the database URL:
# https://www.notion.so/workspace/<DB_ID>?v=...
NOTION_BYTES_DB_ID=
NOTION_SOURCES_DB_ID=

# Cloudflare Web Analytics site token.
# Get it from: Cloudflare dash → Analytics & Logs → Web Analytics → your site
# → "JS snippet" → copy the value of data-cf-beacon's `token` field.
# The PUBLIC_ prefix is required so Astro exposes it to client-rendered HTML.
# Leave blank in local dev to skip the beacon entirely.
PUBLIC_CF_ANALYTICS_TOKEN=
