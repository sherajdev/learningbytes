---
/*
 * ByteList — compact archive-style list of bytes.
 *
 * Used by /bytes, /tags/[tag], /series/[series], /sources/[id].
 * One entry per row: date · format · title. Reverse-chron by default;
 * callers that need a fixed order (series) pass `preserveOrder`.
 */

import type { CollectionEntry } from "astro:content";

interface Props {
  bytes: CollectionEntry<"bytes">[];
  preserveOrder?: boolean;
}

const { bytes, preserveOrder = false } = Astro.props;

const items = preserveOrder
  ? bytes
  : [...bytes].sort(
      (a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime()
    );

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
---

{items.length === 0 ? (
  <p class="opacity-60">Nothing here yet.</p>
) : (
  <ul class="space-y-4">
    {items.map((b) => (
      <li class="flex items-baseline gap-4">
        <time
          datetime={b.data.publishedDate.toISOString()}
          class="shrink-0 text-xs uppercase tracking-[0.15em] opacity-50 tabular-nums"
        >
          {fmt(b.data.publishedDate)}
        </time>
        <span class="shrink-0 text-xs uppercase tracking-[0.15em] opacity-40">
          {b.data.format}
        </span>
        <a href={`/bytes/${b.data.slug}`} class="no-underline hover:underline">
          {b.data.title}
        </a>
      </li>
    ))}
  </ul>
)}
