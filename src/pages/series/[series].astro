---
/*
 * /series/[series] — ordered list of bytes in a series.
 *
 * Unlike tag pages, order here is *not* reverse-chron — it follows the
 * `seriesOrder` frontmatter so part 1 always appears above part 2.
 */

import type { CollectionEntry } from "astro:content";
import type { GetStaticPaths } from "astro";
import { getCollection, getEntry, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SourceLink from "../../components/SourceLink.astro";

export const getStaticPaths: GetStaticPaths = async () => {
  const all = await getCollection("bytes");
  const groups = new Map<string, CollectionEntry<"bytes">[]>();
  for (const b of all) {
    if (!b.data.series) continue;
    if (!groups.has(b.data.series)) groups.set(b.data.series, []);
    groups.get(b.data.series)!.push(b);
  }

  return [...groups.entries()].map(([name, bytes]) => {
    // Sort by seriesOrder (asc). Entries without an order sink to the end.
    const ordered = [...bytes].sort((a, b) => {
      const ao = a.data.seriesOrder ?? Number.POSITIVE_INFINITY;
      const bo = b.data.seriesOrder ?? Number.POSITIVE_INFINITY;
      return ao - bo;
    });
    return { params: { series: name }, props: { bytes: ordered } };
  });
};

interface Props {
  bytes: CollectionEntry<"bytes">[];
}

const { series } = Astro.params;
const { bytes } = Astro.props as Props;
---

<BaseLayout title={series!} description={`Bytes in the "${series}" series.`}>
  <header class="mb-12">
    <p class="text-xs uppercase tracking-[0.15em] opacity-50">
      <a href="/series">Series</a>
    </p>
    <h1 class="mt-2 text-3xl font-bold tracking-tight">{series}</h1>
    <p class="mt-2 opacity-60">
      {bytes.length} {bytes.length === 1 ? "part" : "parts"}
    </p>
  </header>

  {bytes.length === 0 ? (
    <p class="opacity-60">No bytes in this series yet.</p>
  ) : (
    <div class="space-y-16">
      {bytes.map(async (byte) => {
        if (byte.data.format === "Note") {
          const { Content } = await render(byte);
          const sources = (
            await Promise.all(byte.data.sourceIds.map((id) => getEntry("sources", id)))
          ).filter((s): s is typeof s => s !== undefined);
          return (
            <article id={byte.data.slug}>
              <p class="text-xs uppercase tracking-[0.15em] opacity-50">
                Note ·{" "}
                <a href={`/bytes/${byte.data.slug}`} class="note-permalink">
                  <time datetime={byte.data.publishedDate.toISOString()}>
                    {byte.data.publishedDate.toLocaleDateString("en-US", { month: "short", day: "numeric" })}
                  </time>
                </a>
                {byte.data.seriesOrder && <span class="opacity-30"> · part {byte.data.seriesOrder}</span>}
              </p>
              <div class="byte-body byte-body--note mt-4">
                <Content />}
              </div>
              {(sources.length > 0 || byte.data.tags.length > 0) && (
                <div class="mt-4 space-y-2 text-sm opacity-70">
                  {sources.length > 0 && (
                    <p>
                      <span class="opacity-50">inspired by · </span>
                      {sources.map((s, i) => (
                        <>
                          {i > 0 && <span class="opacity-30"> · </span>}
                          <SourceLink source={s} />
                        </>
                      ))}
                    </p>
                  )}
                  {byte.data.tags.length > 0 && (
                    <p class="opacity-60">
                      {byte.data.tags.map((t, i) => (
                        <>
                          {i > 0 && " "}
                          <a href={`/tags/${t}`}>#{t}</a>
                        </>
                      ))}
                    </p>
                  )}
                </div>
              )}
            </article>
          );
        }
        return (
          <article id={byte.data.slug}>
            {byte.data.coverImage && (() => {
              const coverImage = byte.data.coverImage;
              const basePath = coverImage.replace(/-1200\.webp$/, '');
              return (
                <a href={`/bytes/${byte.data.slug}`} class="block mb-4">
                  <img 
                    src={coverImage}
                    srcset={`${basePath}-400.webp 400w, ${basePath}-800.webp 800w, ${basePath}-1200.webp 1200w`}
                    sizes="(max-width: 640px) 100vw, (max-width: 1024px) 800px, 1200px"
                    alt={`Cover for ${byte.data.title}`}
                    class="w-full h-auto rounded-lg"
                    loading="lazy"
                  />
                </a>
              );
            })()}
            <p class="text-xs uppercase tracking-[0.15em] opacity-50">
              Post ·{" "}
              <time datetime={byte.data.publishedDate.toISOString()}>
                {byte.data.publishedDate.toLocaleDateString("en-US", { month: "short", day: "numeric" })}
              </time>
              {byte.data.readingTime && <> · {byte.data.readingTime} min</>}
              {byte.data.seriesOrder && <span class="opacity-30"> · part {byte.data.seriesOrder}</span>}
            </p>
            <h3 class="mt-2 text-2xl font-bold leading-tight tracking-tight">
              <a href={`/bytes/${byte.data.slug}`} class="no-underline">
                {byte.data.title}
              </a>
            </h3>
            {byte.data.excerpt && (
              <p class="mt-3 opacity-70" style="line-height:1.55">
                {byte.data.excerpt}
              </p>
            )}
            <p class="mt-4 text-sm">
              <a href={`/bytes/${byte.data.slug}`}>Read more →</a>
            </p>
          </article>
        );
      })}
    </div>
  )}
</BaseLayout>
