---
/*
 * /tags/[tag] — all bytes that carry a given tag.
 *
 * `getStaticPaths` enumerates every unique tag across the Bytes collection
 * and pre-renders one page per tag. The `bytes` prop is the subset of the
 * collection filtered to that tag — passed through so we don't re-filter
 * at render time.
 */

import type { CollectionEntry } from "astro:content";
import type { GetStaticPaths } from "astro";
import { getCollection, getEntry, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SourceLink from "../../components/SourceLink.astro";

export const getStaticPaths: GetStaticPaths = async () => {
  const all = await getCollection("bytes");
  const byTag = new Map<string, CollectionEntry<"bytes">[]>();
  for (const b of all) {
    for (const t of b.data.tags) {
      if (!byTag.has(t)) byTag.set(t, []);
      byTag.get(t)!.push(b);
    }
  }
  return [...byTag.entries()].map(([tag, bytes]) => ({
    params: { tag },
    props: { bytes },
  }));
};

interface Props {
  bytes: CollectionEntry<"bytes">[];
}

const { tag } = Astro.params;
const { bytes } = Astro.props as Props;
---

<BaseLayout title={`#${tag}`} description={`Bytes tagged #${tag}.`}>
  <header class="mb-12">
    <p class="text-xs uppercase tracking-[0.15em] opacity-50">
      <a href="/tags">Tags</a>
    </p>
    <h1 class="mt-2 text-3xl font-bold tracking-tight">#{tag}</h1>
    <p class="mt-2 opacity-60">
      {bytes.length} {bytes.length === 1 ? "byte" : "bytes"}
    </p>
  </header>

  {bytes.length === 0 ? (
    <p class="opacity-60">No bytes with this tag yet.</p>
  ) : (
    <div class="space-y-16">
      {bytes.map(async (byte) => {
        if (byte.data.format === "Note") {
          const { Content } = await render(byte);
          const sources = (
            await Promise.all(byte.data.sourceIds.map((id) => getEntry("sources", id)))
          ).filter((s): s is typeof s => s !== undefined);
          return (
            <article id={byte.data.slug}>
              <p class="text-xs uppercase tracking-[0.15em] opacity-50">
                Note ·{" "}
                <a href={`/bytes/${byte.data.slug}`} class="note-permalink">
                  <time datetime={byte.data.publishedDate.toISOString()}>
                    {byte.data.publishedDate.toLocaleDateString("en-US", { month: "short", day: "numeric" })}
                  </time>
                </a>
              </p>
              <div class="byte-body byte-body--note mt-4">
                <Content />
              </div>
              {(sources.length > 0 || byte.data.tags.length > 0) && (
                <div class="mt-4 space-y-2 text-sm opacity-70">
                  {sources.length > 0 && (
                    <p>
                      <span class="opacity-50">inspired by · </span>
                      {sources.map((s, i) => (
                        <>
                          {i > 0 && <span class="opacity-30"> · </span>}
                          <SourceLink source={s} />
                        </>
                      ))}
                    </p>
                  )}
                  {byte.data.tags.length > 0 && (
                    <p class="opacity-60">
                      {byte.data.tags.map((tag, i) => (
                        <>
                          {i > 0 && " "}
                          <a href={`/tags/${tag}`}>#{tag}</a>
                        </>
                      ))}
                    </p>
                  )}
                </div>
              )}
            </article>
          );
        }
        return (
          <article id={byte.data.slug}>
            {byte.data.coverImage && (
              <a href={`/bytes/${byte.data.slug}`} class="block mb-4">
                <img 
                  src={byte.data.coverImage}
                  alt={`Cover for ${byte.data.title}`}
                  class="w-full h-auto rounded-lg"
                  loading="lazy"
                />
              </a>
            )}
            <p class="text-xs uppercase tracking-[0.15em] opacity-50">
              Post ·{" "}
              <time datetime={byte.data.publishedDate.toISOString()}>
                {byte.data.publishedDate.toLocaleDateString("en-US", { month: "short", day: "numeric" })}
              </time>
              {byte.data.readingTime && <> · {byte.data.readingTime} min</>}
            </p>
            <h3 class="mt-2 text-2xl font-bold leading-tight tracking-tight">
              <a href={`/bytes/${byte.data.slug}`} class="no-underline">
                {byte.data.title}
              </a>
            </h3>
            {byte.data.excerpt && (
              <p class="mt-3 opacity-70" style="line-height:1.55">
                {byte.data.excerpt}
              </p>
            )}
            <p class="mt-4 text-sm">
              <a href={`/bytes/${byte.data.slug}`}>Read more →</a>
            </p>
          </article>
        );
      })}
    </div>
  )}
</BaseLayout>
